# CES Orchestrator Service Configuration Template

# Application Configuration
PROJECT_NAME=ces-orchestrator
PROJECT_MODULE=ces-orchestrator-service
APP_PORT=8081
LOG_LEVEL=INFO
DB_PROVIDER=postgresql
REDIS_USE=true
LOCALE_LANGUAGE=en
FORMAT_TIMESTAMP=2006-01-02 15:04:05
Backend_CORS=*
ENVIRONMENT=development
MODULE_VERSION=1.0.0
RETENTION_LOG=30

# PostgreSQL Configuration
POSTGRE_SQL_HOST=localhost
POSTGRE_SQL_PORT=5432
POSTGRE_SQL_USER=postgres
POSTGRE_SQL_PASSWORD=postgres
POSTGRE_SQL_DB_NAME=ces_orchestrator
POSTGRE_SQL_MAX_OPEN_CONNECTION=10
POSTGRE_SQL_MAX_IDLE_CONNECTION=5
POSTGRE_SQL_ORCHESTRATOR_USER=ces_orchestrator
POSTGRE_SQL_ORCHESTRATOR_PASSWORD=ces_password

# Redis Configuration
REDIS_URL=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_DURATION=3600
REDIS_WITHOUT_PASSWORD=true

# RabbitMQ Configuration
RABBITMQURL=amqp://guest:guest@localhost:5672/
RABBIT_MQ_HOST=localhost
RABBIT_MQ_PORT=5672
RABBIT_MQ_USERNAME=guest
RABBIT_MQ_PASSWORD=guest
RABBITMQ_STREAM_MAX_AGE=7d
RABBIT_MQ_TIMEOUT=60

# Crypto Configuration
CRYPTO_RSA=your_base64_encoded_rsa_private_key_here

# ElasticSearch Configuration (Optional)
ELASTICSEARCH_URL=http://localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_API_KEY=

# Telemetry Configuration
TELEMETRY_ENABLED=true
TEMPO_ENDPOINT=localhost:4318
PROMETHEUS_PORT=8081