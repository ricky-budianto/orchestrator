		{
			"name": "Workflow Configurations",
			"item": [
				{
					"name": "Create Workflow Configuration",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200 || pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    if (response.data && response.data.id) {",
									"        pm.collectionVariables.set('workflow_config_id', response.data.id);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"demo_flow_v2\",\n  \"name\": \"Demo Flow V2\",\n  \"path\": \"/api/ibridge/v1/demo-flow-v2\",\n  \"method\": \"POST\",\n  \"descriptions\": \"Demo workflow for testing orchestration\",\n  \"configuration\": \"name: demo_flow_v2\\nrequestType: demo_flow_v2\\npath: /api/ibridge/v1/demo-flow-v2\\nmethod: POST\\nstartEvent:\\n  targetRef: demo_check_email\\n\\nserviceTask:\\n  demo_check_email:\\n    type: worker\\n    sourceRefParsing: ${{ibridge.httprequest}}\\n    sourceRef:\\n      authorization: ${{startEvent.Authorization}}\\n      body:\\n        email: ${{startEvent.Body.email}}\\n    targetRef:\\n      - condition_demo_check_email\\n    worker: middleware\\n\\n  condition_demo_check_email:\\n    type: conditional\\n    condition:\\n      variableCheck:\\n        - ${{demo_check_email.data.data.disposable_email}}\\n      value:\\n        - case:\\n          - true\\n          target: ibridge-reply\\n          status_code: 400\\n          save_global:\\n            status_code: 400\\n            message: \\\"Invalid email\\\"\\n            error_code: \\\"5001\\\"\\n    defaultTask: demo_get_result\\n\\n  demo_get_result:\\n    type: worker\\n    sourceRefParsing: ${{ibridge.httprequest}}\\n    sourceRef:\\n      authorization: ${{startEvent.Authorization}}\\n      body:\\n        email_score: ${{demo_check_email.data.data.score}}\\n        processed_at: ${{demo_check_email.data.timestamp}}\\n    targetRef:\\n      - ibridge-reply\\n    worker: middleware\\n\\n  ibridge-reply:\\n    endParsing: Separated\\n    sourceRef:\\n      step_check_email: ${{demo_check_email.data}}\\n      step_get_result: ${{demo_get_result.data}}\\n    type: endEvent\\n    taskRef: ibridge-reply\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/ibridge/v1/workflow_configuration",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"ibridge",
								"v1",
								"workflow_configuration"
							]
						}
					},
					"response": []
				},
